# macOS / editor files
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Local WP runtime and machine-specific files
conf/
logs/
app/.env
app/.env.*
app/.envrc

# Database dumps and generated exports
app/sql/
*.sql
*.sql.gz
*.sqlite

# Ignore the local WordPress install by default: core, generated files,
# third-party themes/plugins, local config and uploads should not live in Git.
app/public/*

# Keep only source files owned by this project.
!app/public/wp-config.example.php
!app/public/wp-content/

app/public/wp-content/*
!app/public/wp-content/themes/
!app/public/wp-content/mu-plugins/
!app/public/wp-content/uploads/

app/public/wp-content/themes/*
!app/public/wp-content/themes/blocksy-child/
!app/public/wp-content/themes/blocksy-child/**

app/public/wp-content/mu-plugins/*
!app/public/wp-content/mu-plugins/aperture-workflow.php

app/public/wp-content/uploads/*

# Keep generated Blocksy CSS that is needed to preserve the current visual style.
!app/public/wp-content/uploads/blocksy/
!app/public/wp-content/uploads/blocksy/**

# WordPress runtime folders, in case they are introduced in tracked areas.
app/public/.maintenance
app/public/error_log
app/public/wp-content/debug.log
app/public/wp-content/cache/
app/public/wp-content/upgrade/

# Backup plugins commonly write here
app/public/wp-content/ai1wm-backups/
app/public/wp-content/backups/
app/public/wp-content/backup-db/
app/public/wp-content/updraft/

# Dependency/build output if tools are run inside themes/plugins
node_modules/
vendor/
!app/public/wp-content/themes/blocksy-child/vendor/
dist/
build/
